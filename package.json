{
  "name": "ai-bookmark-os",
  "private": true,
  "version": "1.0.3",
  "license": "MIT",
  "description": "AI-assisted local-first bookmark management and classification for Chrome.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jxh-YG/ai-bookmark-os.git"
  },
  "homepage": "https://github.com/jxh-YG/ai-bookmark-os",
  "type": "module",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "test:e2e": "node scripts/e2e-extension.mjs",
    "dev": "vite build --watch",
    "build:ai": "tsc -b && vite build",
    "build:ext": "node scripts/package-extension.mjs",
    "build": "npm run build:ai && npm run build:ext",
    "typecheck": "tsc -b --noEmit",
    "test:checker": "node scripts/test-checker.mjs && node scripts/test-checker-permission.mjs && node scripts/test-link-checker-core.mjs",
    "test:quick-bookmark": "node scripts/test-quick-bookmark.mjs",
    "test:regressions": "node scripts/test-regressions.mjs",
    "preview:check": "node scripts/verify-build.mjs",
    "audit:project": "node scripts/audit-project.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.3"
  }
}
